# Telegram Bot API. Заполните значения перед запуском.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Параметры WheelsParser (пустое значение = значение по умолчанию)
CHECK_INTERVAL=
REQUEST_TIMEOUT=
MESSAGES_PER_CHANNEL=
MAX_SEEN_PER_CHANNEL=
MAX_RESULTS=
WHEELS_WINDOW_MINUTES=
ACTIVE_MAX_AGE_HOURS=
ACTIVE_CHECK_CONCURRENCY=
REALERT_COOLDOWN_MINUTES=
PRECHECK_WHEELS=
STALE_COMMAND_SECONDS=
CHANNEL_FAIL_THRESHOLD=
ALERT_ON_FIRST_RUN=

# Оформление консоли
USE_COLORS=
USE_ICONS=

# --- Twitch ---
# Мониторинг Twitch-чатов (анонимно, токены не нужны). Ловятся только ссылки
# betboom.ru/freestream от стримера/модераторов/VIP/ботов, без ключевых слов.
# TWITCH_ENABLED=true
# Список каналов через запятую — только для первого запуска, пока нет
# twitch_channels.txt; дальше управляйте через файл или /addtwitch, /removetwitch.
# WHEELSPARSER_TWITCH_CHANNELS=streamer1,streamer2
# Боты, чьи ссылки принимаются даже без бейджа модератора.
# TWITCH_BOTS=nightbot,streamelements,moobot,fossabot,wizebot,streamlabs
